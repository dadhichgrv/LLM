# Define State
class State(TypedDict):
    query: str
    rewritten_query: str  # Rewritten query for web search
    docs: List[Document]
    doc_scores: List[float]  # Scores for each document
    filtered_docs: List[Document]  # Docs that pass upper threshold
    verdict: str  # "Good" if all >= upper, "Bad" if all <= lower, "Ambiguous" otherwise
    reason: str  # Explanation of why verdict was chosen
    
    sentences: List[str]
    relevant_sentences: List[str]
    relevant_context: str
    web_results: list[Document]  # Results from web search
    messages: Annotated[list[BaseMessage], add_messages]  # Messages for tool calling

    answer: str

# Thresholds for relevance
UPPER_THRESHOLD = 0.7
LOWER_THRESHOLD = 0.3

# Tavily Search Tool instance
web_search_tool = TavilySearchResults(max_results=3)

# Web Search 
def web_search(query: str) -> str:
    """Search the web for information about the given query."""
    search_results = web_search_tool.invoke(query)
    
    if search_results:
        web_context = "\n\n".join([
            f"Source: {result.get('url', 'N/A')}\nContent: {result.get('content', '')}" 
            for result in search_results
        ])
    else:
        web_context = "No web results found."
    
    return web_context


# Define Retrieve Node
def retrieve_node(state: State):
    """Retrieve relevant documents based on query"""
    query = state['query']
    similar_docs = retriever.invoke(query)
    return {"docs": similar_docs}

# Define Evaluator Node
def evaluator_node(state: State):
    """Evaluate each document's relevance to the query and assign scores"""
    query = state['query']
    docs = state['docs']
    
    doc_scores = []
    filtered_docs = []
    reasons_info = []
    
    for i, doc in enumerate(docs):
        response = evaluator_chain.invoke({"document": doc.page_content, "query": query})
        score = max(0.0, min(1.0, response.score))  # Clamp between 0 and 1
        doc_scores.append(score)
        reasons_info.append(f"Doc {i+1} (score: {score:.2f}): {response.reason}")
        
        # Keep docs that pass the upper threshold for refinement
        if score >= UPPER_THRESHOLD:
            filtered_docs.append(doc)
    
    # Determine verdict based on document scores
    any_above_upper = any(score >= UPPER_THRESHOLD for score in doc_scores) if doc_scores else False
    all_below_lower = all(score <= LOWER_THRESHOLD for score in doc_scores) if doc_scores else True
    
    if any_above_upper:
        verdict = "Good"
        reason = f"{len(filtered_docs)} document(s) are highly relevant (score >= {UPPER_THRESHOLD}). Using only those docs. {'; '.join(reasons_info)}"
    elif all_below_lower:
        verdict = "Bad"
        reason = f"All {len(docs)} document(s) are irrelevant (all scores <= {LOWER_THRESHOLD}). {'; '.join(reasons_info)}"
    else:
        verdict = "Ambiguous"
        reason = f"No documents above upper threshold ({UPPER_THRESHOLD}), but not all below lower threshold ({LOWER_THRESHOLD}). {'; '.join(reasons_info)}"
    
    return {"doc_scores": doc_scores, "filtered_docs": filtered_docs, "verdict": verdict, "reason": reason}

# Conditional routing based on verdict
def route_after_evaluation(state: State):
    """Route based on verdict: Good -> refine, Bad/Ambiguous -> rewrite_query"""
    if state['verdict'] == "Good":
        return "refine"
    else:  # Bad or Ambiguous - both go through web search
        return "rewrite_query"

# Define Reject Node
def reject_node(state: State):
    """Return message when documents are not relevant enough"""
    return {"answer": f"The retrieved documents are not relevant enough to answer the query. Verdict: {state['verdict']}. Reason: {state['reason']}"}

# Define Rewrite Query Node
def rewrite_query(state: State):
    """Rewrite the user query to be more suitable for web search"""
    query = state['query']
    
    prompt = f"""You are a query rewriter. Given the user's question, rewrite it to be a better search query for web search.
Make it more specific and search-engine friendly. Return only the rewritten query, nothing else.

Original question: {query}

Rewritten search query:"""
    
    response = client_chat_oai.invoke([HumanMessage(content=prompt)])
    rewritten = response.content.strip()
    
    return {"rewritten_query": rewritten}

# Define Web Search Node
def web_search_node(state: State):
    """Perform web search and convert results to Documents for refinement"""
    # Use rewritten query if available, otherwise use original query
    query = state.get('rewritten_query') or state['query']
    
    # Call the web_search tool function directly
    web_context = web_search(query)
    
    # Convert web results to Document objects
    web_docs = [Document(page_content=web_context, metadata={"source": "web_search"})]
    
    # For Ambiguous verdict: combine existing filtered_docs with web_docs
    # For Bad verdict: filtered_docs will be empty, so only web_docs are used
    existing_filtered_docs = state.get('filtered_docs', [])
    combined_docs = existing_filtered_docs + web_docs
    
    return {"filtered_docs": combined_docs, "web_results": web_context}

def refine(state: State):
    """Split filtered docs into sentences and filter by relevance"""
    # Split filtered docs into sentences
    sentences = []
    for doc in state['filtered_docs']:
        sentences.extend(split_text_into_sentences(doc.page_content))
    
    # Filter sentences using the filter chain
    relevant_sentences = []
    for sentence in sentences:
        response = filter_chain.invoke({"sentences": sentence, "query": state['query']})
        if response.keep:
            relevant_sentences.append(sentence)
    
    # Merge relevant sentences into context
    relevant_context = " ".join(relevant_sentences)
    
    return {"sentences": sentences, "relevant_sentences": relevant_sentences, "relevant_context": relevant_context}


# Define Generate Node
def generate(state: State):
    relevant_context = state['relevant_context']
    
    if not relevant_context:
        return {"answer": "No relevant information found to answer the query."}
    
    prompt = f"""Use the following context to answer the question. 
If you cannot find the answer in the context, you can use the web_search tool to find more information.

Question: {state['query']}
Context: {relevant_context}

"""
    # Use llm_with_tools so it can call tools if needed
    response = client_chat_oai.invoke([HumanMessage(content=prompt)])
    
    # If response has tool_calls, we need to return messages for the tool_node to process
    if hasattr(response, 'tool_calls') and response.tool_calls:
        return {"messages": [response]}
    
    return {"answer": response.content, "messages": [response]}    


graph = StateGraph(State)
graph.add_node("retrieve", retrieve_node)
graph.add_node("evaluator", evaluator_node)
graph.add_node("refine", refine)
graph.add_node("rewrite_query", rewrite_query)
graph.add_node("web_search", web_search_node)
graph.add_node("generate", generate)

graph.add_edge(START, "retrieve")
graph.add_edge("retrieve", "evaluator")
graph.add_conditional_edges("evaluator", route_after_evaluation, {
    "refine": "refine", 
    "rewrite_query": "rewrite_query"
})
graph.add_edge("refine", "generate")
graph.add_edge("rewrite_query", "web_search")
graph.add_edge("web_search", "refine")
graph.add_edge("generate", END)

